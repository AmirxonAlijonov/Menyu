# Telegram Bot Configuration
# Copy this file to .env and fill in your values
# Get BOT_TOKEN from @BotFather on Telegram
# Get CHAT_ID from @userinfobot on Telegram

# Bot credentials
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
CHAT_ID=YOUR_CHAT_ID_HERE

# Ruxsat etilgan foydalanuvchilar (faqat bu foydalanuvchilar botdan foydalanishi mumkin)
# Chat ID larni vergul bilan ajrating: ALLOWED_USERS=123456789,987654321
# Hamma uchun ochiq qilish uchun bu qatorni to'liq o'chirib yuboring
ALLOWED_USERS=

# Server port (optional, default is 3000)
# PORT=3000
