{
  "version": 2,
  "builds": [
    {
      "src": "api/order.js",
      "use": "@vercel/node"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/order",
      "dest": "/api/order.js"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/index.js",
      "dest": "/index.js"
    },
    {
      "src": "/CSS/style.css",
      "dest": "/CSS/style.css"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*).html",
      "dest": "/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "BOT_TOKEN": "8658618667:AAHiS_SKKpj6z6Y78nGf0zd456PBfa79Mbo",
    "CHAT_ID": "5968349865"
  }
}