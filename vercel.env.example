# Vercel Environment Variables  
# Copy these values to Vercel Dashboard - Settings - Variables  
  
# Telegram Bot Configuration (required)  
BOT_TOKEN=YOUR_BOT_TOKEN_HERE  
CHAT_ID=YOUR_CHAT_ID_HERE  
  
# Allowed Users (optional - leave empty for public access)  
# Format: comma-separated chat IDs: "123456789,987654321"  
ALLOWED_USERS=  
  
# Server Port (optional, Vercel will set its own PORT)  
PORT=3001 
